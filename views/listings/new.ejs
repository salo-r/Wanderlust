<%= layout("/layouts/boilerPlate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3>Create a New Listing</h3>

    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input
          required
          name="listing[title]"
          placeholder="enter title"
          type="text"
          class="form-control"
        />
        <div class="valid-feedback">Title Looks good!</div>
        <div class="invalid-feedback">Please give a title.</div>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea
          required
          name="listing[description]"
          placeholder="enter description"
          class="form-control"
        ></textarea>
        <div class="valid-feedback">Description looks good!</div>
        <div class="invalid-feedback">Please enter a short description.</div>
      </div>

       <div class="mb-3">
        <label for="img" class="form-label" class="form-label"
          >Upload listing Image</label
        >
        <input
          name="listing[image]"
          type="file"
          class="form-control" required
        />
      </div>

      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Price</label>
          <input
            required
            name="listing[price]"
            placeholder="enter price"
       
            class="form-control"
          />
          <div class="valid-feedback">Price looks good!</div>
          <div class="invalid-feedback">Please enter valid price.</div>
        </div>

        <div class="mb-3 col-md-8">
          <label for="country" class="form-label">Country</label>
          <input
            required
            name="listing[country]"
            class="form-control"
            placeholder="enter country"
            type="text"
          />
          <div class="valid-feedback">Country looks good!</div>
          <div class="invalid-feedback">Please enter a valid country name.</div>
        </div>
      </div>
      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input
          required
          class="form-control"
          name="listing[location]"
          placeholder="enter location"
          type="text"
        />
        <div class="valid-feedback">Location is valid !</div>
        <div class="invalid-feedback">Please enter a location.</div>
      </div>

      <button class="mt-3 btn btn-dark add-btn">Add</button>
    </form>
  </div>
</div>
